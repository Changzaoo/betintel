rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Users ----
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---- Public sports data (cache) ----
    match /fixtures_cache/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server-side writes
    }

    match /team_stats_cache/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /player_stats_cache/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /head_to_head_cache/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /predictions/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ---- Favorites ----
    match /favorites/{docId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ---- Alerts ----
    match /alerts/{docId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ---- Admin only ----
    match /admin_config/{docId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
