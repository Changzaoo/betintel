{
  "name": "betintel-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@betintel/web",
    "dev:web": "npm run dev --workspace=@betintel/web",
    "dev:api": "npm run dev --workspace=@betintel/api",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build:web",
    "build:web": "npm run build --workspace=@betintel/web",
    "build:api": "npm run build --workspace=@betintel/api",
    "preview": "npm run preview --workspace=@betintel/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
