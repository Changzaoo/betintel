# ========================
# FRONTEND - Firebase (públicas, prefixo VITE_)
# ========================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# URL da API backend
VITE_API_URL=http://localhost:3001

# ========================
# BACKEND - Nunca expor no frontend
# ========================

# API-Football / API-Sports (https://www.api-football.com)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# SportMonks (https://www.sportmonks.com)
SPORTMONKS_KEY=
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3

# Sportradar (https://developer.sportradar.com)
SPORTRADAR_KEY=
SPORTRADAR_BASE_URL=https://api.sportradar.us

# Firebase Admin SDK (backend only)
FIREBASE_PROJECT_ID=aposta-1fee6
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# App config
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
