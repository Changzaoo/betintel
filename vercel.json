{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "apps/web/dist/**",
      "use": "@vercel/static"
    },
    {
      "src": "apps/api/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web/dist/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
